#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
#  Atomik Bench — Lightweight Linux Benchmark Suite
#  https://github.com/giurest/atomik-os
#
#  Eseguibile su qualsiasi distro Linux. Produce un report JSON confrontabile.
#  Uso:  curl -fsSL https://raw.githubusercontent.com/giurest/atomik-os/main/tools/atomik-bench | bash
#        oppure:  ./atomik-bench [--no-gpu] [--output FILE]
# ═══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

VERSION="1.0.0"
BENCH_DIR="${HOME}/.local/share/atomik-bench"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
NO_GPU=false
OUTPUT_FILE=""

# ── Colori ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Argomenti ─────────────────────────────────────────────────────────────────
for arg in "$@"; do
    case "$arg" in
        --no-gpu)   NO_GPU=true ;;
        --help|-h)
            echo "Atomik Bench v${VERSION} — Lightweight Linux Benchmark Suite"
            echo ""
            echo "Uso: atomik-bench [opzioni]"
            echo ""
            echo "Opzioni:"
            echo "  --no-gpu         Salta i benchmark GPU"
            echo "  --output FILE    Salva il report JSON in FILE"
            echo "  --help           Mostra questo messaggio"
            exit 0
            ;;
        --output=*)  OUTPUT_FILE="${arg#*=}" ;;
        --output)    ;; # il prossimo arg sarà il file
        *)
            # cattura il valore dopo --output
            if [[ "${PREV_ARG:-}" == "--output" ]]; then
                OUTPUT_FILE="$arg"
            fi
            ;;
    esac
    PREV_ARG="$arg"
done

mkdir -p "$BENCH_DIR"
[[ -z "$OUTPUT_FILE" ]] && OUTPUT_FILE="${BENCH_DIR}/bench_${TIMESTAMP}.json"

# ── Funzioni utilità ──────────────────────────────────────────────────────────
header() {
    echo -e "\n${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD}  $1${NC}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
}

step() {
    echo -e "  ${GREEN}▸${NC} $1"
}

warn() {
    echo -e "  ${YELLOW}⚠${NC} $1"
}

fail() {
    echo -e "  ${RED}✗${NC} $1"
}

# ── Detect package manager ────────────────────────────────────────────────────
detect_pkg_manager() {
    if command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    elif command -v zypper &>/dev/null; then
        echo "zypper"
    else
        echo "unknown"
    fi
}

# ── Detect sistema immutabile ─────────────────────────────────────────────────
is_immutable() {
    command -v bootc &>/dev/null || command -v rpm-ostree &>/dev/null
}

# ── Attiva overlay temporaneo su sistemi immutabili ──────────────────────────
activate_overlay() {
    if command -v bootc &>/dev/null; then
        step "Sistema immutabile (bootc) — attivo overlay temporaneo..."
        if sudo bootc usr-overlay 2>/dev/null; then
            step "Overlay attivo (temporaneo, scompare al reboot)"
        else
            warn "bootc usr-overlay fallito (potrebbe essere già attivo)"
        fi
    elif command -v rpm-ostree &>/dev/null; then
        step "Sistema immutabile (rpm-ostree)"
    fi
}

# ── Installa dipendenze ──────────────────────────────────────────────────────
install_deps() {
    local pkgmgr
    pkgmgr=$(detect_pkg_manager)
    local missing=()

    # Controlla quali tool mancano
    command -v sysbench &>/dev/null || missing+=("sysbench")
    command -v fio &>/dev/null      || missing+=("fio")
    command -v bc &>/dev/null       || missing+=("bc")

    if [[ "$NO_GPU" == false ]]; then
        command -v glmark2 &>/dev/null || missing+=("glmark2")
    fi

    if [[ ${#missing[@]} -eq 0 ]]; then
        step "Tutte le dipendenze sono già installate"
        return 0
    fi

    step "Dipendenze mancanti: ${missing[*]}"

    # Chiedi conferma
    echo -en "  ${YELLOW}?${NC} Installare le dipendenze? (temporaneo, scompare al reboot) [S/n] "
    read -r risposta
    if [[ "$risposta" =~ ^[Nn] ]]; then
        warn "Alcune benchmark potrebbero essere saltate"
        return 0
    fi

    # Su sistemi immutabili, attiva overlay prima di installare
    if is_immutable; then
        activate_overlay
    fi

    case "$pkgmgr" in
        dnf)
            if command -v rpm-ostree &>/dev/null && ! command -v bootc &>/dev/null; then
                # Silverblue/Kinoite puro (senza bootc): usa rpm-ostree
                sudo rpm-ostree install --apply-live "${missing[@]}" 2>/dev/null || true
            else
                # bootc con overlay attivo, oppure Fedora tradizionale
                sudo dnf install -y --skip-unavailable "${missing[@]}" 2>/dev/null || true
            fi
            ;;
        apt)
            sudo apt-get update -qq
            sudo apt-get install -y "${missing[@]}" 2>/dev/null || true
            ;;
        pacman)
            sudo pacman -S --noconfirm --needed "${missing[@]}" 2>/dev/null || true
            ;;
        zypper)
            sudo zypper install -y "${missing[@]}" 2>/dev/null || true
            ;;
        *)
            warn "Package manager non riconosciuto, installa manualmente: ${missing[*]}"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════════════════
#  RACCOLTA INFO SISTEMA
# ═══════════════════════════════════════════════════════════════════════════════
collect_sysinfo() {
    header "Raccolta informazioni sistema"

    # OS
    if [[ -f /etc/os-release ]]; then
        OS_NAME=$(. /etc/os-release && echo "${PRETTY_NAME:-$NAME}")
        OS_ID=$(. /etc/os-release && echo "${ID:-unknown}")
    else
        OS_NAME=$(uname -o)
        OS_ID="unknown"
    fi
    step "OS: ${OS_NAME}"

    # Kernel
    KERNEL=$(uname -r)
    step "Kernel: ${KERNEL}"

    # CPU
    CPU_MODEL=$(lscpu 2>/dev/null | grep 'Nome modello\|Model name' | head -1 | sed 's/.*:\s*//' | xargs)
    CPU_CORES=$(nproc)
    CPU_THREADS=$(lscpu 2>/dev/null | grep '^CPU(s):\|^CPU:' | head -1 | awk '{print $NF}')
    [[ -z "$CPU_THREADS" ]] && CPU_THREADS="$CPU_CORES"
    step "CPU: ${CPU_MODEL} (${CPU_CORES}C/${CPU_THREADS}T)"

    # RAM
    RAM_TOTAL_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    RAM_TOTAL_MB=$((RAM_TOTAL_KB / 1024))
    RAM_TOTAL_GB=$(echo "scale=1; $RAM_TOTAL_KB / 1048576" | bc 2>/dev/null || echo "$((RAM_TOTAL_MB / 1024))")
    step "RAM: ${RAM_TOTAL_GB} GB"

    # GPU
    GPU_NAME="N/A"
    if command -v lspci &>/dev/null; then
        GPU_NAME=$(lspci 2>/dev/null | grep -iE 'VGA|3D|Display' | head -1 | sed 's/.*: //' | \
            sed 's/Advanced Micro Devices, Inc. \[AMD\/ATI\]/AMD/' | \
            sed 's/NVIDIA Corporation /NVIDIA /' | \
            sed 's/Intel Corporation /Intel /' | \
            xargs)
    fi
    step "GPU: ${GPU_NAME}"

    # Disco root — gestisce NVMe, SATA, LUKS, dm-crypt, btrfs, composefs/ostree/bootc
    DISK_MODEL="N/A"

    # Funzione per risalire al disco fisico da un device
    _find_phys_disk() {
        local dev="$1"
        [[ -z "$dev" || "$dev" == "overlay" || "$dev" == "composefs" || ! -e "$dev" ]] && return 1
        local current="$dev"
        local parent
        for _ in 1 2 3; do
            parent=$(lsblk -ndo PKNAME "$current" 2>/dev/null || echo "")
            [[ -z "$parent" ]] && break
            current="/dev/$parent"
        done
        local model
        model=$(lsblk -dno MODEL "$current" 2>/dev/null | xargs)
        [[ -n "$model" ]] && echo "$model"
    }

    # Prova in ordine: /sysroot, /boot, /var/home, /var, / (per distro normali)
    for mnt in /sysroot /boot /var/home /var /; do
        local src
        src=$(findmnt -n -o SOURCE "$mnt" 2>/dev/null | sed 's/\[.*//' | head -1)
        DISK_MODEL=$(_find_phys_disk "$src" || echo "")
        [[ -n "$DISK_MODEL" && "$DISK_MODEL" != " " ]] && break
    done

    # Fallback ultimo: primo disco fisico con un MODEL (salta zram e loop)
    if [[ -z "$DISK_MODEL" || "$DISK_MODEL" == " " ]]; then
        DISK_MODEL=$(lsblk -dno MODEL 2>/dev/null | grep -v '^$' | head -1 | xargs || echo "N/A")
    fi

    # Size dal mount reale
    DISK_SIZE=$(df -h /sysroot 2>/dev/null | tail -1 | awk '{print $2}')
    [[ -z "$DISK_SIZE" || "$DISK_SIZE" == "-" ]] && DISK_SIZE=$(df -h / | tail -1 | awk '{print $2}')

    [[ -z "$DISK_MODEL" || "$DISK_MODEL" == " " ]] && DISK_MODEL="N/A"
    step "Disco: ${DISK_MODEL} (${DISK_SIZE})"

    # Init system
    INIT_SYSTEM="unknown"
    if command -v systemctl &>/dev/null; then
        INIT_SYSTEM="systemd"
    fi

    # bootc/immutable
    IMMUTABLE=false
    if is_immutable; then
        IMMUTABLE=true
    fi
    step "Immutabile: ${IMMUTABLE}"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: RAM A IDLE
# ═══════════════════════════════════════════════════════════════════════════════
bench_ram_idle() {
    header "Benchmark: RAM a idle"

    RAM_USED_KB=$(grep -E '^MemTotal:|^MemAvailable:' /proc/meminfo | awk '
        /MemTotal/    { total=$2 }
        /MemAvailable/{ avail=$2 }
        END           { print total - avail }
    ')
    RAM_USED_MB=$((RAM_USED_KB / 1024))
    step "RAM utilizzata a idle: ${RAM_USED_MB} MB"

    BENCH_RAM_IDLE=$RAM_USED_MB
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: BOOT TIME
# ═══════════════════════════════════════════════════════════════════════════════
bench_boot() {
    header "Benchmark: Boot time"

    BENCH_BOOT_FIRMWARE="N/A"
    BENCH_BOOT_LOADER="N/A"
    BENCH_BOOT_KERNEL="N/A"
    BENCH_BOOT_INITRD="N/A"
    BENCH_BOOT_USERSPACE="N/A"
    BENCH_BOOT_TOTAL="N/A"

    if command -v systemd-analyze &>/dev/null; then
        local boot_output
        boot_output=$(systemd-analyze 2>/dev/null || true)

        if [[ -n "$boot_output" ]]; then
            # Formato: "Startup finished in 14.962s (firmware) + 3.350s (loader) + 971ms (kernel) + 20.606s (initrd) + 10.153s (userspace) = 50.044s"
            # Il tempo può essere in secondi (Xs) o millisecondi (Xms)
            _boot_extract() {
                local label="$1"
                local val
                # Prova formato "Xs (label)"
                val=$(echo "$boot_output" | grep -oP '[0-9.]+s\s*\('"$label"'\)' | grep -oP '[0-9.]+' || echo "")
                if [[ -n "$val" ]]; then
                    echo "$val"
                    return
                fi
                # Prova formato "Xms (label)" → converti in secondi
                val=$(echo "$boot_output" | grep -oP '[0-9.]+ms\s*\('"$label"'\)' | grep -oP '[0-9.]+' || echo "")
                if [[ -n "$val" ]]; then
                    LC_ALL=C printf '%.3f' "$(echo "scale=3; $val / 1000" | bc 2>/dev/null || echo 0)"
                    return
                fi
                # Prova formato "Xmin Ys (label)"
                local mins secs
                mins=$(echo "$boot_output" | grep -oP '[0-9.]+min\s*[0-9.]*s?\s*\('"$label"'\)' | grep -oP '[0-9.]+min' | grep -oP '[0-9.]+' || echo "")
                secs=$(echo "$boot_output" | grep -oP '[0-9.]+min\s*\K[0-9.]+s\s*\('"$label"'\)' | grep -oP '[0-9.]+' || echo "0")
                if [[ -n "$mins" ]]; then
                    echo "scale=3; $mins * 60 + $secs" | bc 2>/dev/null || echo "0"
                    return
                fi
                echo "N/A"
            }

            BENCH_BOOT_FIRMWARE=$(_boot_extract firmware)
            BENCH_BOOT_LOADER=$(_boot_extract loader)
            BENCH_BOOT_KERNEL=$(_boot_extract kernel)
            BENCH_BOOT_INITRD=$(_boot_extract initrd)
            BENCH_BOOT_USERSPACE=$(_boot_extract userspace)
            BENCH_BOOT_TOTAL=$(echo "$boot_output" | grep -oP '=\s*[0-9.]+s' | grep -oP '[0-9.]+' || echo "N/A")

            step "Firmware:  ${BENCH_BOOT_FIRMWARE}s"
            step "Loader:    ${BENCH_BOOT_LOADER}s"
            step "Kernel:    ${BENCH_BOOT_KERNEL}s"
            step "Initrd:    ${BENCH_BOOT_INITRD}s"
            step "Userspace: ${BENCH_BOOT_USERSPACE}s"
            step "Totale:    ${BENCH_BOOT_TOTAL}s"
        else
            warn "systemd-analyze non disponibile in questo contesto"
        fi
    else
        warn "systemd non presente, boot time non misurabile"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: CPU (sysbench)
# ═══════════════════════════════════════════════════════════════════════════════
bench_cpu() {
    header "Benchmark: CPU"

    BENCH_CPU_SINGLE="N/A"
    BENCH_CPU_MULTI="N/A"

    if ! command -v sysbench &>/dev/null; then
        warn "sysbench non installato, CPU benchmark saltato"
        return 0
    fi

    # Single-thread
    step "CPU single-thread (10s)..."
    local single_out
    single_out=$(sysbench cpu --threads=1 --time=10 run 2>/dev/null)
    BENCH_CPU_SINGLE=$(echo "$single_out" | grep 'events per second' | awk '{print $NF}')
    step "Single-thread: ${BENCH_CPU_SINGLE} events/s"

    # Multi-thread
    step "CPU multi-thread (10s, ${CPU_CORES} threads)..."
    local multi_out
    multi_out=$(sysbench cpu --threads="$CPU_CORES" --time=10 run 2>/dev/null)
    BENCH_CPU_MULTI=$(echo "$multi_out" | grep 'events per second' | awk '{print $NF}')
    step "Multi-thread:  ${BENCH_CPU_MULTI} events/s"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: MEMORIA (sysbench)
# ═══════════════════════════════════════════════════════════════════════════════
bench_memory() {
    header "Benchmark: Memoria"

    BENCH_MEM_READ="N/A"
    BENCH_MEM_WRITE="N/A"

    if ! command -v sysbench &>/dev/null; then
        warn "sysbench non installato, memory benchmark saltato"
        return 0
    fi

    # Read
    step "Memoria read (10s)..."
    local read_out
    read_out=$(sysbench memory --memory-oper=read --threads="$CPU_CORES" --time=10 run 2>/dev/null)
    BENCH_MEM_READ=$(echo "$read_out" | grep -i 'transferred' | grep -oP '[\d.]+\s*MiB/sec' | head -1 || echo "N/A")
    step "Read:  ${BENCH_MEM_READ}"

    # Write
    step "Memoria write (10s)..."
    local write_out
    write_out=$(sysbench memory --memory-oper=write --threads="$CPU_CORES" --time=10 run 2>/dev/null)
    BENCH_MEM_WRITE=$(echo "$write_out" | grep -i 'transferred' | grep -oP '[\d.]+\s*MiB/sec' | head -1 || echo "N/A")
    step "Write: ${BENCH_MEM_WRITE}"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: DISCO (fio o dd fallback)
# ═══════════════════════════════════════════════════════════════════════════════
bench_disk() {
    header "Benchmark: Disco"

    BENCH_DISK_SEQ_READ="N/A"
    BENCH_DISK_SEQ_WRITE="N/A"
    BENCH_DISK_RAND_READ="N/A"
    BENCH_DISK_RAND_WRITE="N/A"

    local test_dir="${BENCH_DIR}/fio_test"
    mkdir -p "$test_dir"

    if command -v fio &>/dev/null; then
        # Usa python3 per parsing JSON affidabile (sempre disponibile su distro moderne)
        _fio_val() {
            # $1 = json output, $2 = "read" o "write", $3 = "bw_bytes" o "iops"
            echo "$1" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d['jobs'][0]['$2']['$3'])
except: print('0')
" 2>/dev/null || echo "0"
        }

        # Sequential write
        step "Disco sequential write (1GB)..."
        local sw_out
        sw_out=$(fio --name=seq_write --directory="$test_dir" --size=1G \
            --bs=1M --rw=write --numjobs=1 --time_based --runtime=10 \
            --group_reporting --output-format=json 2>/dev/null || echo '{}')
        BENCH_DISK_SEQ_WRITE=$(LC_ALL=C python3 -c "print(int($(_fio_val "$sw_out" write bw_bytes) / 1048576))" 2>/dev/null || echo "0")
        step "Seq Write: ${BENCH_DISK_SEQ_WRITE} MB/s"

        # Sequential read
        step "Disco sequential read (1GB)..."
        local sr_out
        sr_out=$(fio --name=seq_read --directory="$test_dir" --size=1G \
            --bs=1M --rw=read --numjobs=1 --time_based --runtime=10 \
            --group_reporting --output-format=json 2>/dev/null || echo '{}')
        BENCH_DISK_SEQ_READ=$(LC_ALL=C python3 -c "print(int($(_fio_val "$sr_out" read bw_bytes) / 1048576))" 2>/dev/null || echo "0")
        step "Seq Read:  ${BENCH_DISK_SEQ_READ} MB/s"

        # Random read 4K
        step "Disco random read 4K..."
        local rr_out
        rr_out=$(fio --name=rand_read --directory="$test_dir" --size=256M \
            --bs=4k --rw=randread --numjobs=4 --time_based --runtime=10 \
            --group_reporting --output-format=json 2>/dev/null || echo '{}')
        BENCH_DISK_RAND_READ=$(LC_ALL=C python3 -c "print(int($(_fio_val "$rr_out" read iops)))" 2>/dev/null || echo "0")
        step "Rand Read 4K: ${BENCH_DISK_RAND_READ} IOPS"

        # Random write 4K
        step "Disco random write 4K..."
        local rw_out
        rw_out=$(fio --name=rand_write --directory="$test_dir" --size=256M \
            --bs=4k --rw=randwrite --numjobs=4 --time_based --runtime=10 \
            --group_reporting --output-format=json 2>/dev/null || echo '{}')
        BENCH_DISK_RAND_WRITE=$(LC_ALL=C python3 -c "print(int($(_fio_val "$rw_out" write iops)))" 2>/dev/null || echo "0")
        step "Rand Write 4K: ${BENCH_DISK_RAND_WRITE} IOPS"

    else
        # Fallback: dd
        warn "fio non installato, uso dd (meno preciso)"

        step "Disco write (dd 1GB)..."
        local dd_write
        dd_write=$(dd if=/dev/zero of="${test_dir}/dd_test" bs=1M count=1024 conv=fdatasync 2>&1 | tail -1)
        BENCH_DISK_SEQ_WRITE=$(echo "$dd_write" | grep -oP '[\d.,]+\s*[MG]B/s' || echo "N/A")
        step "Write: ${BENCH_DISK_SEQ_WRITE}"

        step "Disco read (dd 1GB)..."
        sync && echo 3 | sudo tee /proc/sys/vm/drop_caches &>/dev/null || true
        local dd_read
        dd_read=$(dd if="${test_dir}/dd_test" of=/dev/null bs=1M 2>&1 | tail -1)
        BENCH_DISK_SEQ_READ=$(echo "$dd_read" | grep -oP '[\d.,]+\s*[MG]B/s' || echo "N/A")
        step "Read:  ${BENCH_DISK_SEQ_READ}"
    fi

    # Pulizia
    rm -rf "$test_dir"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  BENCHMARK: GPU (glmark2)
# ═══════════════════════════════════════════════════════════════════════════════
bench_gpu() {
    header "Benchmark: GPU"

    BENCH_GPU_SCORE="N/A"

    if [[ "$NO_GPU" == true ]]; then
        warn "GPU benchmark saltato (--no-gpu)"
        return 0
    fi

    if ! command -v glmark2 &>/dev/null; then
        warn "glmark2 non installato, GPU benchmark saltato"
        return 0
    fi

    # Serve un display
    if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
        warn "Nessun display attivo, GPU benchmark saltato"
        return 0
    fi

    step "GPU glmark2 benchmark..."
    local gpu_out
    local glmark_cmd="glmark2"

    # Su Wayland usa glmark2-wayland se disponibile
    if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        if command -v glmark2-wayland &>/dev/null; then
            glmark_cmd="glmark2-wayland"
        elif command -v glmark2-es2-wayland &>/dev/null; then
            glmark_cmd="glmark2-es2-wayland"
        fi
    fi

    gpu_out=$($glmark_cmd 2>/dev/null || true)
    BENCH_GPU_SCORE=$(echo "$gpu_out" | grep -i 'glmark2 Score' | grep -oP '[\d]+' | tail -1 || echo "N/A")
    [[ -z "$BENCH_GPU_SCORE" ]] && BENCH_GPU_SCORE="N/A"
    step "glmark2 Score: ${BENCH_GPU_SCORE}"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  CONTEGGIO PACCHETTI
# ═══════════════════════════════════════════════════════════════════════════════
count_packages() {
    BENCH_PACKAGES="N/A"

    if command -v rpm &>/dev/null; then
        BENCH_PACKAGES=$(rpm -qa 2>/dev/null | wc -l)
    elif command -v dpkg &>/dev/null; then
        BENCH_PACKAGES=$(dpkg -l 2>/dev/null | grep '^ii' | wc -l)
    elif command -v pacman &>/dev/null; then
        BENCH_PACKAGES=$(pacman -Q 2>/dev/null | wc -l)
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
#  GENERA REPORT JSON
# ═══════════════════════════════════════════════════════════════════════════════
generate_json() {
    cat > "$OUTPUT_FILE" << JSONEOF
{
  "atomik_bench_version": "${VERSION}",
  "timestamp": "${TIMESTAMP}",
  "date": "$(date -Iseconds)",
  "system": {
    "os": "${OS_NAME}",
    "os_id": "${OS_ID}",
    "kernel": "${KERNEL}",
    "immutable": ${IMMUTABLE},
    "packages": ${BENCH_PACKAGES},
    "cpu": {
      "model": "${CPU_MODEL}",
      "cores": ${CPU_CORES},
      "threads": ${CPU_THREADS:-${CPU_CORES}}
    },
    "ram_total_mb": ${RAM_TOTAL_MB},
    "gpu": "${GPU_NAME}",
    "disk": "${DISK_MODEL}"
  },
  "results": {
    "ram_idle_mb": ${BENCH_RAM_IDLE:-0},
    "boot": {
      "firmware_s": "${BENCH_BOOT_FIRMWARE}",
      "loader_s": "${BENCH_BOOT_LOADER}",
      "kernel_s": "${BENCH_BOOT_KERNEL}",
      "initrd_s": "${BENCH_BOOT_INITRD}",
      "userspace_s": "${BENCH_BOOT_USERSPACE}",
      "total_s": "${BENCH_BOOT_TOTAL}"
    },
    "cpu": {
      "single_thread_eps": "${BENCH_CPU_SINGLE}",
      "multi_thread_eps": "${BENCH_CPU_MULTI}"
    },
    "memory": {
      "read": "${BENCH_MEM_READ}",
      "write": "${BENCH_MEM_WRITE}"
    },
    "disk": {
      "seq_read_mbs": "${BENCH_DISK_SEQ_READ}",
      "seq_write_mbs": "${BENCH_DISK_SEQ_WRITE}",
      "rand_read_iops": "${BENCH_DISK_RAND_READ}",
      "rand_write_iops": "${BENCH_DISK_RAND_WRITE}"
    },
    "gpu": {
      "glmark2_score": "${BENCH_GPU_SCORE}"
    }
  }
}
JSONEOF
}

# ═══════════════════════════════════════════════════════════════════════════════
#  REPORT TERMINALE
# ═══════════════════════════════════════════════════════════════════════════════
print_report() {
    header "Report Atomik Bench v${VERSION}"

    echo -e "\n${DIM}  Sistema${NC}"
    echo -e "  ┌─────────────────────┬──────────────────────────────────────────┐"
    printf "  │ %-19s │ %-40s │\n" "OS"        "$OS_NAME"
    printf "  │ %-19s │ %-40s │\n" "Kernel"    "$KERNEL"
    printf "  │ %-19s │ %-40s │\n" "CPU"       "$CPU_MODEL"
    printf "  │ %-19s │ %-40s │\n" "Core/Thread" "${CPU_CORES}C / ${CPU_THREADS:-$CPU_CORES}T"
    printf "  │ %-19s │ %-40s │\n" "RAM"       "${RAM_TOTAL_GB} GB"
    printf "  │ %-19s │ %-40s │\n" "GPU"       "$GPU_NAME"
    printf "  │ %-19s │ %-40s │\n" "Disco"     "$DISK_MODEL"
    printf "  │ %-19s │ %-40s │\n" "Immutabile" "$IMMUTABLE"
    printf "  │ %-19s │ %-40s │\n" "Pacchetti"  "$BENCH_PACKAGES"
    echo -e "  └─────────────────────┴──────────────────────────────────────────┘"

    echo -e "\n${DIM}  Risultati${NC}"
    echo -e "  ┌─────────────────────┬──────────────────────────────────────────┐"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "RAM idle"        "${BENCH_RAM_IDLE:-N/A} MB"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Boot totale"     "${BENCH_BOOT_TOTAL:-N/A}s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Boot kernel"     "${BENCH_BOOT_KERNEL:-N/A}s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Boot initrd"     "${BENCH_BOOT_INITRD:-N/A}s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Boot userspace"  "${BENCH_BOOT_USERSPACE:-N/A}s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "CPU single"      "${BENCH_CPU_SINGLE:-N/A} events/s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "CPU multi"       "${BENCH_CPU_MULTI:-N/A} events/s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Mem read"        "${BENCH_MEM_READ:-N/A}"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Mem write"       "${BENCH_MEM_WRITE:-N/A}"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Disco seq read"  "${BENCH_DISK_SEQ_READ:-N/A} MB/s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Disco seq write" "${BENCH_DISK_SEQ_WRITE:-N/A} MB/s"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Disco rand read" "${BENCH_DISK_RAND_READ:-N/A} IOPS"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "Disco rand write" "${BENCH_DISK_RAND_WRITE:-N/A} IOPS"
    printf "  │ ${GREEN}%-19s${NC} │ %-40s │\n" "GPU glmark2"     "${BENCH_GPU_SCORE:-N/A}"
    echo -e "  └─────────────────────┴──────────────────────────────────────────┘"

    echo -e "\n  ${DIM}Report salvato in:${NC} ${BOLD}${OUTPUT_FILE}${NC}\n"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═══════════════════════════════════════════════════════════════════════════════
main() {
    echo -e "\n${BOLD}  ⚡ Atomik Bench v${VERSION}${NC}"
    echo -e "  ${DIM}Lightweight Linux Benchmark Suite${NC}"
    echo -e "  ${DIM}https://github.com/giurest/atomik-os${NC}\n"

    install_deps
    collect_sysinfo
    count_packages
    bench_ram_idle
    bench_boot
    bench_cpu
    bench_memory
    bench_disk
    bench_gpu
    generate_json
    print_report
}

main "$@"
