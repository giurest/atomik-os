# ═══════════════════════════════════════════════════════════════════════════════
#  Atomik OS — Variante Server
#  Host minimale container-oriented. Parte da fedora-bootc, NESSUNA eredità
#  dal ramo desktop. Solo Podman + tooling essenziale + ujust server.
# ═══════════════════════════════════════════════════════════════════════════════

# Stage ctx: porta i build_files nel contesto di build
FROM scratch AS ctx
COPY build_files_server /

# Immagine finale
FROM quay.io/fedora/fedora-bootc:44

LABEL org.opencontainers.image.title="Atomik OS Server"
LABEL org.opencontainers.image.description="Atomik OS — variante Server minimale, host per container (base fedora-bootc)"

RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    bash /ctx/build.sh

# Justfile server (sorgente in files/ujust, come le altre varianti)
COPY files/ujust/server-justfile /usr/share/atomik-server/justfile

# ── Atomik Changelog ──────────────────────────────────────────────────────────
COPY files/system/usr/bin/atomik-changelog /usr/bin/atomik-changelog
RUN chmod +x /usr/bin/atomik-changelog

RUN bootc container lint
