cat > packages/puregaming.list << 'EOF'
# ── Atomik OS — pacchetti variante PureGaming ────────────────────────────────

# ── Shell e terminale ─────────────────────────────────────────────────────────
fish
starship

# ── Compositor Niri ──────────────────────────────────────────────────────────
niri
waybar
fuzzel
mako
swaylock
wl-clipboard
grim
slurp

# ── Tema ─────────────────────────────────────────────────────────────────────
papirus-icon-theme

# ── Gaming ───────────────────────────────────────────────────────────────────
# steam, wine, heroic, lutris, protonplus via Flatpak
gamemode
gamescope
mangohud
vkBasalt
goverlay

# ── Compatibilità gaming ─────────────────────────────────────────────────────
vulkan-loader
vulkan-tools
mesa-vulkan-drivers
mesa-dri-drivers
libva
libva-utils

# ── SCX Scheduler ────────────────────────────────────────────────────────────
scx-scheds

# ── Multimedia ───────────────────────────────────────────────────────────────
pipewire
wireplumber
pipewire-pulseaudio
pipewire-alsa

# ── Sistema ──────────────────────────────────────────────────────────────────
distrobox
podman
flatpak
NetworkManager
NetworkManager-wifi
bluez

# ── CLI tools ────────────────────────────────────────────────────────────────
fastfetch
htop
eza
bat

# ── Login manager ────────────────────────────────────────────────────────────
gdm
EOF