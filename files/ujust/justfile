# [Manutenzione] Ripristina configurazione MangoHud di default
reset-mangohud:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p ~/.config/MangoHud
    cp /usr/share/atomik/defaults/MangoHud/MangoHud.conf \
       ~/.config/MangoHud/MangoHud.conf
    echo "✓ Configurazione MangoHud ripristinata."

# [Manutenzione] Abilita MangoHud (per gioco o globalmente)
mangohud-enable:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "┌──────────────────────────────────────┐"
    echo "│  MangoHud — Modalità di attivazione  │"
    echo "└──────────────────────────────────────┘"
    echo ""
    echo "  1) Per gioco    — controllo manuale su ogni titolo"
    echo "  2) Globale      — attivo su tutti i giochi automaticamente"
    echo ""
    read -rp "Scelta [1/2]: " CHOICE
    echo ""
    if [[ "$CHOICE" == "1" ]]; then
        echo "── Attivazione per gioco ──"
        echo ""
        echo "  Steam:"
        echo "    → Tasto destro sul gioco → Proprietà"
        echo "    → Opzioni di avvio:"
        echo "      mangohud %command%"
        echo ""
        echo "  Heroic:"
        echo "    → Impostazioni del gioco → Variabili d'ambiente"
        echo "    → Aggiungi: MANGOHUD = 1"
        echo ""
        echo "  Toggle overlay in-game: Shift_R+F12"
    elif [[ "$CHOICE" == "2" ]]; then
        mkdir -p "$HOME/.config/environment.d"
        echo 'MANGOHUD=1' > "$HOME/.config/environment.d/mangohud.conf"
        systemctl --user import-environment MANGOHUD 2>/dev/null || true
        echo "✓ MangoHud attivato globalmente."
        echo "⚠ Riavvia la sessione (logout/login) per applicare."
        echo "⚠ Per giochi Proton usa anche: mangohud %command% nelle opzioni di avvio del singolo gioco che non viene riconosciuto"
        echo ""
        echo "  Heroic:"
        echo "    → Impostazioni → Impostazioni di gioco predefinite"
        echo "    → Variabili d'ambiente → Aggiungi: MANGOHUD = 1"
        echo ""
        echo "  ⚠ Riavvia la sessione (logout/login) per applicare."
        echo "  ⚠ Per giochi Proton usa anche: mangohud %command%"
        echo "  Toggle overlay in-game: Shift_R+F12"
    else
        echo "✗ Scelta non valida."
        exit 1
    fi

# [Manutenzione] Installa WinBoat (Windows app runner via container)
install-winboat:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "→ Verifica prerequisiti..."
    if ! flatpak info com.freerdp.FreeRDP &>/dev/null; then
        echo "→ Installazione FreeRDP 3..."
        flatpak install -y --noninteractive --system flathub com.freerdp.FreeRDP
        echo "✓ FreeRDP installato"
    else
        echo "✓ FreeRDP già presente"
    fi
    echo "→ Scarico l'ultima versione di WinBoat..."
    URL=$(curl -s https://api.github.com/repos/TibixDev/winboat/releases/latest \
        | grep "browser_download_url.*AppImage" \
        | head -1 \
        | cut -d '"' -f 4)
    if [ -z "$URL" ]; then
        echo "✗ Impossibile trovare l'AppImage nelle release."
        exit 1
    fi
    TMPFILE=$(mktemp /tmp/WinBoat-XXXX.AppImage)
    curl -fSL "$URL" -o "$TMPFILE"
    chmod +x "$TMPFILE"
    echo "→ Integrazione con Gear Lever..."
    flatpak run it.mijorus.gearlever --integrate "$TMPFILE"
    rm -f "$TMPFILE"
    echo ""
    echo "✓ WinBoat installato e integrato nel launcher."
    echo "  Prerequisiti: Podman (✓), FreeRDP (✓), KVM abilitato"

# [Manutenzione] Sblocca WinBoat (riavvia il container)
unlock-winboat:
    #!/usr/bin/env bash
    set -euo pipefail
    WINBOAT_DIR="$HOME/.winboat"
    if [ ! -d "$WINBOAT_DIR" ]; then
        echo "✗ WinBoat non trovato in $WINBOAT_DIR"
        exit 1
    fi
    cd "$WINBOAT_DIR"
    echo "→ Arresto container WinBoat..."
    if podman-compose down 2>&1 | tail -3; then
        echo "  ✓ Container fermato"
    else
        echo "  ⚠ Nessun container attivo da fermare"
    fi
    echo ""
    echo "→ Avvio container WinBoat..."
    if podman-compose up -d 2>&1 | tail -5; then
        echo ""
        echo "┌──────────────────────────────────────┐"
        echo "│  ✓ WinBoat pronto                    │"
        echo "│  Stato container:                     │"
        podman ps --filter "name=winboat" 2>/dev/null | tail -1 || true
        echo "└──────────────────────────────────────┘"
    else
        echo "  ✗ Errore nell'avvio del container"
        exit 1
    fi

# [Manutenzione] Applica le regole udev o configurazioni rapide che abbiamo visto prima
fix-solaar:
    @echo "Applicazione permessi Solaar e uinput..."
    sudo curl -sSL https://raw.githubusercontent.com/pwr-Solaar/Solaar/master/rules.d-uinput/42-logitech-unify-permissions.rules -o /etc/udev/rules.d/42-logitech-unify-permissions.rules
    sudo udevadm control --reload-rules && sudo udevadm trigger
    flatpak override --user --device=all io.github.pwr_solaar.solaar    


# ── SMB / Condivisioni di rete ───────────────────────────────────────────────
 
# [Rete] Crea una connessione SMB persistente (NAS, PC Windows)
smb-connect:
    #!/usr/bin/env bash
    set -euo pipefail
    USER_HOME="$(realpath "$HOME")"
    USERNAME="$(whoami)"
    USER_UID=$(id -u)
    echo "┌──────────────────────────────────────┐"
    echo "│  Connessione SMB / Condivisione rete │"
    echo "└──────────────────────────────────────┘"
    echo ""
    read -rp "Nome cartella contenitore (es. nas, shares): " CONTAINER
    if [[ -z "$CONTAINER" ]]; then
        echo "✗ Nome contenitore vuoto."; exit 1
    fi
    mkdir -p "$USER_HOME/$CONTAINER"
    read -rp "Nome connessione (es. server1, backup, media): " CONNECTION
    if [[ -z "$CONNECTION" ]]; then
        echo "✗ Nome connessione vuoto."; exit 1
    fi
    MOUNT_PATH="$USER_HOME/$CONTAINER/$CONNECTION"
    if mountpoint -q "$MOUNT_PATH" 2>/dev/null; then
        echo "✗ '$MOUNT_PATH' è già un mount attivo."
        exit 1
    fi
    mkdir -p "$MOUNT_PATH"
    read -rp "Descrizione (es. NAS Ufficio): " DESCRIPTION
    read -rp "Percorso remoto (es. //192.168.178.100/dati): " REMOTE_PATH
    read -rp "Utente SMB: " SMB_USER
    read -srp "Password SMB: " SMB_PASS
    echo ""
    UNIT_NAME=$(systemd-escape --path "$MOUNT_PATH")
    echo ""
    echo "→ Configurazione:"
    echo "  Mount:  $MOUNT_PATH"
    echo "  Remote: $REMOTE_PATH"
    echo "  Utente: $SMB_USER"
    echo "  Unit:   $UNIT_NAME"
    echo ""
    read -rp "Confermi? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    MOUNT_CONTENT="[Unit]\nDescription=$DESCRIPTION\n\n[Mount]\nWhat=$REMOTE_PATH\nWhere=$MOUNT_PATH\nType=cifs\nOptions=rw,file_mode=0700,dir_mode=0700,uid=$USER_UID,user=$SMB_USER,password=$SMB_PASS\nDirectoryMode=0700\n\n[Install]\nWantedBy=multi-user.target"
    printf "$MOUNT_CONTENT\n" | sudo tee /etc/systemd/system/${UNIT_NAME}.mount > /dev/null
    AUTOMOUNT_CONTENT="[Unit]\nDescription=$DESCRIPTION (automount)\n\n[Automount]\nWhere=$MOUNT_PATH\nTimeoutIdleSec=60\n\n[Install]\nWantedBy=multi-user.target"
    printf "$AUTOMOUNT_CONTENT\n" | sudo tee /etc/systemd/system/${UNIT_NAME}.automount > /dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now ${UNIT_NAME}.automount
    echo ""
    echo "✓ Connessione '$CONNECTION' creata e attiva."
    echo "  Accedi a: $MOUNT_PATH"
    echo "  Si monta automaticamente al primo accesso."
 
# [Rete] Rimuovi una connessione SMB
smb-disconnect:
    #!/usr/bin/env bash
    set -euo pipefail
    USER_HOME="$(realpath "$HOME")"
    echo "┌──────────────────────────────────────┐"
    echo "│  Rimozione connessione SMB           │"
    echo "└──────────────────────────────────────┘"
    echo ""
    read -rp "Nome cartella contenitore (es. nas): " CONTAINER
    read -rp "Nome connessione da rimuovere (es. server1): " CONNECTION
    MOUNT_PATH="$USER_HOME/$CONTAINER/$CONNECTION"
    UNIT_NAME=$(systemd-escape --path "$MOUNT_PATH")
    if [[ ! -f "/etc/systemd/system/${UNIT_NAME}.mount" ]]; then
        echo "✗ Nessuna connessione trovata per '$MOUNT_PATH'."
        exit 1
    fi
    echo ""
    echo "⚠ Verrà rimossa la connessione:"
    echo "  Mount: $MOUNT_PATH"
    echo "  Unit:  $UNIT_NAME"
    echo ""
    read -rp "Confermi? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    sudo systemctl disable --now ${UNIT_NAME}.automount 2>/dev/null || true
    sudo systemctl disable --now ${UNIT_NAME}.mount 2>/dev/null || true
    sudo rm -f /etc/systemd/system/${UNIT_NAME}.mount
    sudo rm -f /etc/systemd/system/${UNIT_NAME}.automount
    sudo systemctl daemon-reload
    read -rp "Eliminare anche la cartella '$MOUNT_PATH'? [s/N]: " DELFOLDER
    if [[ "$DELFOLDER" =~ ^[sS]$ ]]; then
        rm -rf "$MOUNT_PATH"
        echo "✓ Cartella rimossa."
    fi
    echo "✓ Connessione '$CONNECTION' rimossa."
 
# [Rete] Elenca le connessioni SMB attive
smb-list:
    #!/usr/bin/env bash
    echo "┌──────────────────────────────────────┐"
    echo "│  Connessioni SMB attive              │"
    echo "└──────────────────────────────────────┘"
    echo ""
    FOUND=0
    for f in /etc/systemd/system/var-*.mount; do
        [ -f "$f" ] || continue
        UNIT=$(basename "$f")
        WHERE=$(grep "^Where=" "$f" | cut -d= -f2)
        WHAT=$(grep "^What=" "$f" | cut -d= -f2)
        STATUS=$(systemctl is-active "${UNIT%.mount}.automount" 2>/dev/null || echo "inattivo")
        echo "  $WHERE → $WHAT [$STATUS]"
        FOUND=1
    done
    if [ "$FOUND" -eq 0 ]; then
        echo "  Nessuna connessione SMB configurata."
    fi
 
# [Manutenzione] Powerwash: backup dati essenziali + reset completo del sistema
powerwash:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "┌──────────────────────────────────────┐"
    echo "│  ⚠ POWERWASH — Reset di sistema     │"
    echo "└──────────────────────────────────────┘"
    echo ""
    echo "Flusso di lavoro:"
    echo "  1. Salva SOLO le cartelle scelte su un dispositivo esterno"
    echo "  2. Resetta completamente il sistema (etc, var, flatpak)"
    echo "  3. Al riavvio il sistema sarà come appena installato"
    echo ""
    echo "⚠ TUTTO il resto verrà cancellato: config, app, flatpak, cache."
    echo ""
    read -rp "Continuare? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    USER_HOME="$(realpath "$HOME")"
    USERNAME="$(whoami)"
    echo ""
    echo "── Cartelle da salvare ──"
    echo "Default: Documenti Immagini Video Musica Scaricati"
    read -rp "Cartelle aggiuntive (separate da spazio, vuoto per solo default): " EXTRA
    FOLDERS="Documenti Documents Immagini Pictures Video Videos Musica Music Scaricati Downloads $EXTRA"
    echo ""
    echo "── Destinazione backup ──"
    echo "Dispositivi montati:"
    lsblk -o NAME,SIZE,MOUNTPOINT,FSTYPE | grep -v "loop" | grep -v "^$"
    echo ""
    read -rp "Percorso destinazione (es. /run/media/$USERNAME/USB): " DEST
    if [ ! -d "$DEST" ]; then
        echo "✗ Percorso '$DEST' non trovato."
        exit 1
    fi
    BACKUP_FILE="$DEST/atomik-powerwash-$(date +%Y%m%d-%H%M%S).tar.gz"
    echo ""
    echo "── Creazione backup ──"
    BACKUP_ARGS=""
    for DIR in $FOLDERS; do
        FULL_PATH="$USER_HOME/$DIR"
        if [ -d "$FULL_PATH" ]; then
            echo "  + $DIR"
            BACKUP_ARGS="$BACKUP_ARGS $DIR"
        fi
    done
    if [ -z "$BACKUP_ARGS" ]; then
        echo "✗ Nessuna cartella trovata da salvare."
        exit 1
    fi
    echo ""
    echo "→ Salvataggio in $BACKUP_FILE ..."
    cd "$USER_HOME"
    tar czf "$BACKUP_FILE" $BACKUP_ARGS
    BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
    echo "✓ Backup completato ($BACKUP_SIZE)"
    echo ""
    echo "── Reset sistema ──"
    VARIANT=$(grep "^PRETTY_NAME" /etc/os-release | sed 's/.*(\(.*\)).*/\1/' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
    IMAGE="ghcr.io/giurest/atomik-${VARIANT}:latest"
    echo "Variante rilevata: $VARIANT"
    echo "Immagine: $IMAGE"
    echo ""
    echo "⚠ ULTIMO AVVISO: il sistema verrà resettato al prossimo riavvio."
    echo "  Il backup è stato salvato su: $BACKUP_FILE"
    echo "  SCOLLEGA il dispositivo esterno DOPO il riavvio."
    echo ""
    read -rp "Procedere con il reset? [s/N]: " FINAL
    if [[ ! "$FINAL" =~ ^[sS]$ ]]; then
        echo "Reset annullato. Il backup resta in: $BACKUP_FILE"
        exit 0
    fi
    echo "→ Preparazione reset..."
    sudo /usr/bin/atomik-powerwash-prepare
    echo "→ Switch immagine..."
    sudo bootc switch --mutate-in-place --transport registry "$IMAGE"
    echo ""
    echo "┌──────────────────────────────────────┐"
    echo "│  ✓ Powerwash preparato               │"
    echo "│                                       │"
    echo "│  Al prossimo riavvio:                 │"
    echo "│  • Sistema resettato ai default       │"
    echo "│  • Home pulite                        │"
    echo "│  • Flatpak rimossi                    │"
    echo "│                                       │"
    echo "│  Backup salvato su dispositivo esterno│"
    echo "│                                       │"
    echo "│  Riavvia quando pronto:               │"
    echo "│  sudo systemctl reboot                │"
    echo "└──────────────────────────────────────┘"

# ── SSH ──────────────────────────────────────────────────────────────────────

# [Rete] Abilita e avvia il server SSH
sshd:
    #!/usr/bin/env bash
    if systemctl is-active --quiet sshd.service; then
        echo "✓ sshd è già attivo"
    else
        echo "→ Attivazione sshd..."
        sudo systemctl enable --now sshd.service
        echo "✓ sshd attivato e avviato"
    fi
    echo ""
    USER=$(whoami)
    IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
    if [ -n "$IP" ]; then
        echo "┌──────────────────────────────────────┐"
        echo "│  Connettiti con:                     │"
        echo "│  ssh ${USER}@${IP}"
        echo "└──────────────────────────────────────┘"
    else
        echo "⚠ Nessun indirizzo IP trovato"
    fi
    echo ""
    echo "Stato: $(systemctl is-active sshd.service) | Abilitato al boot: $(systemctl is-enabled sshd.service)"

# [Rete] Disabilita e ferma il server SSH
sshd-off:
    #!/usr/bin/env bash
    if systemctl is-active --quiet sshd.service; then
        echo "→ Arresto sshd..."
        sudo systemctl disable --now sshd.service
        echo "✓ sshd disattivato e fermato"
    else
        echo "✓ sshd è già spento"
        if systemctl is-enabled --quiet sshd.service 2>/dev/null; then
            echo "→ Rimuovo avvio automatico..."
            sudo systemctl disable sshd.service
            echo "✓ Rimosso dal boot"
        fi
    fi

# [Manutenzione] Pulisci le immagini bootc non più referenziate
cleanup:
    sudo bootc image prune 2>/dev/null || sudo podman image prune -f
    @echo "✓ Pulizia completata."
