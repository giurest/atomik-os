# Atomik OS — system justfile (ujust)
# Eseguito tramite il wrapper `ujust`.

# Mostra l'elenco delle ricette disponibili
_default:
    @just --list --unsorted --justfile {{justfile()}}

# ─────────────────────────────────────────────────────────────────────────────
# Gestione utenti
# ─────────────────────────────────────────────────────────────────────────────

# Crea un nuovo utente con home e shell, aggiunto al gruppo wheel (sudo)
create-user username="":
    #!/usr/bin/env bash
    set -euo pipefail
    USERNAME="{{username}}"
    if [[ -z "$USERNAME" ]]; then
        read -rp "Nome utente da creare: " USERNAME
    fi
    if [[ -z "$USERNAME" ]]; then
        echo "Errore: nome utente vuoto."
        exit 1
    fi
    if id "$USERNAME" &>/dev/null; then
        echo "L'utente '$USERNAME' esiste già."
        exit 1
    fi
    sudo useradd -m -G wheel -s /usr/bin/bash "$USERNAME"
    echo "Imposta la password per '$USERNAME':"
    sudo passwd "$USERNAME"
    echo "✓ Utente '$USERNAME' creato e aggiunto al gruppo wheel."

# Elimina un utente esistente (opzionalmente con la sua home)
delete-user username="":
    #!/usr/bin/env bash
    set -euo pipefail
    USERNAME="{{username}}"
    if [[ -z "$USERNAME" ]]; then
        read -rp "Nome utente da eliminare: " USERNAME
    fi
    if [[ -z "$USERNAME" ]]; then
        echo "Errore: nome utente vuoto."
        exit 1
    fi
    if ! id "$USERNAME" &>/dev/null; then
        echo "L'utente '$USERNAME' non esiste."
        exit 1
    fi
    read -rp "Eliminare anche la home directory? [s/N]: " DELHOME
    if [[ "$DELHOME" =~ ^[sS]$ ]]; then
        sudo userdel -r "$USERNAME"
        echo "✓ Utente '$USERNAME' e home eliminati."
    else
        sudo userdel "$USERNAME"
        echo "✓ Utente '$USERNAME' eliminato (home conservata)."
    fi

# Cambia la password di un utente
passwd-user username="":
    #!/usr/bin/env bash
    set -euo pipefail
    USERNAME="{{username}}"
    if [[ -z "$USERNAME" ]]; then
        read -rp "Utente di cui cambiare la password: " USERNAME
    fi
    sudo passwd "$USERNAME"

# Aggiungi o rimuovi i privilegi sudo (gruppo wheel) per un utente
toggle-sudo username="":
    #!/usr/bin/env bash
    set -euo pipefail
    USERNAME="{{username}}"
    if [[ -z "$USERNAME" ]]; then
        read -rp "Utente: " USERNAME
    fi
    if id -nG "$USERNAME" | grep -qw wheel; then
        sudo gpasswd -d "$USERNAME" wheel
        echo "✓ Privilegi sudo rimossi da '$USERNAME'."
    else
        sudo gpasswd -a "$USERNAME" wheel
        echo "✓ Privilegi sudo concessi a '$USERNAME'."
    fi

# Elenca gli utenti umani del sistema (UID >= 1000)
list-users:
    #!/usr/bin/env bash
    awk -F: '$3 >= 1000 && $3 < 65534 { print $1 " (uid " $3 ")" }' /etc/passwd

# ─────────────────────────────────────────────────────────────────────────────
# Sistema (bootc)
# ─────────────────────────────────────────────────────────────────────────────

# Aggiorna Atomik OS all'ultima immagine disponibile
update:
    @echo "Controllo aggiornamenti Atomik OS…"
    sudo bootc upgrade

# Mostra lo stato corrente dell'immagine bootc
status:
    sudo bootc status

# Torna alla versione precedente del sistema (rollback)
rollback:
    @echo "Rollback alla versione precedente…"
    sudo bootc rollback
    @echo "✓ Riavvia per applicare il rollback."

# Riavvia il sistema
reboot:
    sudo systemctl reboot

# ─────────────────────────────────────────────────────────────────────────────
# Manutenzione
# ─────────────────────────────────────────────────────────────────────────────

# Ripristina TUTTA la configurazione desktop (Niri + DMS + Fastfetch + Wallpaper)
reset-desktop:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "⚠ Questa operazione sovrascriverà le configurazioni attuali di:"
    echo "  • Niri (config.kdl, binds, window rules)"
    echo "  • DMS (settings.json)"
    echo "  • Fastfetch"
    echo "  • Wallpaper"
    echo ""
    echo "Le personalizzazioni correnti andranno perse."
    echo ""
    read -rp "Continuare? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    echo ""
    echo "→ Reset configurazione Niri..."
    mkdir -p ~/.config/niri/dms
    cp /usr/share/atomik/defaults/niri/config.kdl ~/.config/niri/config.kdl
    cp /usr/share/atomik/defaults/niri/dms/binds.kdl ~/.config/niri/dms/binds.kdl
    cp /usr/share/atomik/defaults/niri/dms/windowrules.kdl ~/.config/niri/dms/windowrules.kdl
    echo "→ Reset configurazione DMS..."
    mkdir -p ~/.config/DankMaterialShell
    cp /usr/share/atomik/defaults/DankMaterialShell/settings.json ~/.config/DankMaterialShell/settings.json
    echo "→ Reset Fastfetch..."
    mkdir -p ~/.config/fastfetch
    ln -sf /etc/fastfetch/config.jsonc ~/.config/fastfetch/config.jsonc
    ln -sf /etc/fastfetch/atomik-logo.txt ~/.config/fastfetch/atomik-logo.txt
    echo "→ Reset Wallpaper..."
    dms ipc call wallpaper set /usr/share/backgrounds/atomik/wall.jpg 2>/dev/null || true
    echo ""
    echo "✓ Configurazione desktop ripristinata."
    echo "  Riavvia DMS o fai logout/login per applicare."

# Reimposta il wallpaper di Atomik
set-wallpaper:
    dms ipc call wallpaper set /usr/share/backgrounds/atomik/wall.jpg
    @echo "✓ Wallpaper Atomik impostato."

# Ripristina la configurazione fastfetch di default
reset-fastfetch:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p ~/.config/fastfetch
    ln -sf /etc/fastfetch/config.jsonc ~/.config/fastfetch/config.jsonc
    ln -sf /etc/fastfetch/atomik-logo.txt ~/.config/fastfetch/atomik-logo.txt
    echo "✓ Configurazione fastfetch ripristinata."

# Installa WinBoat (Windows app runner via container)
install-winboat:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "→ Verifica prerequisiti..."
    if ! flatpak info com.freerdp.FreeRDP &>/dev/null; then
        echo "→ Installazione FreeRDP 3..."
        flatpak install -y --noninteractive --system flathub com.freerdp.FreeRDP
        echo "✓ FreeRDP installato"
    else
        echo "✓ FreeRDP già presente"
    fi
    echo "→ Scarico l'ultima versione di WinBoat..."
    URL=$(curl -s https://api.github.com/repos/TibixDev/winboat/releases/latest \
        | grep "browser_download_url.*AppImage" \
        | head -1 \
        | cut -d '"' -f 4)
    if [ -z "$URL" ]; then
        echo "✗ Impossibile trovare l'AppImage nelle release."
        exit 1
    fi
    TMPFILE=$(mktemp /tmp/WinBoat-XXXX.AppImage)
    curl -fSL "$URL" -o "$TMPFILE"
    chmod +x "$TMPFILE"
    echo "→ Integrazione con Gear Lever..."
    flatpak run it.mijorus.gearlever --integrate "$TMPFILE"
    rm -f "$TMPFILE"
    echo ""
    echo "✓ WinBoat installato e integrato nel launcher."
    echo "  Prerequisiti: Podman (✓), FreeRDP (✓), KVM abilitato"

# Installa WinBoat (Windows app runner via container)
unlock-winboat:
    #!/usr/bin/env bash
    set -euo pipefail
    cd ~/.winboat
    podman-compose down
    podman-compose up -d    
    echo "  Pod Winboat: Riavviato (✓)"


# ── SMB / Condivisioni di rete ───────────────────────────────────────────────
 
# Crea una connessione SMB persistente (NAS, PC Windows)
smb-connect:
    #!/usr/bin/env bash
    set -euo pipefail
    USER_HOME="$(realpath "$HOME")"
    USERNAME="$(whoami)"
    USER_UID=$(id -u)
    echo "┌──────────────────────────────────────┐"
    echo "│  Connessione SMB / Condivisione rete │"
    echo "└──────────────────────────────────────┘"
    echo ""
    read -rp "Nome cartella contenitore (es. nas, shares): " CONTAINER
    if [[ -z "$CONTAINER" ]]; then
        echo "✗ Nome contenitore vuoto."; exit 1
    fi
    mkdir -p "$USER_HOME/$CONTAINER"
    read -rp "Nome connessione (es. server1, backup, media): " CONNECTION
    if [[ -z "$CONNECTION" ]]; then
        echo "✗ Nome connessione vuoto."; exit 1
    fi
    MOUNT_PATH="$USER_HOME/$CONTAINER/$CONNECTION"
    if mountpoint -q "$MOUNT_PATH" 2>/dev/null; then
        echo "✗ '$MOUNT_PATH' è già un mount attivo."
        exit 1
    fi
    mkdir -p "$MOUNT_PATH"
    read -rp "Descrizione (es. NAS Ufficio): " DESCRIPTION
    read -rp "Percorso remoto (es. //192.168.178.100/dati): " REMOTE_PATH
    read -rp "Utente SMB: " SMB_USER
    read -srp "Password SMB: " SMB_PASS
    echo ""
    UNIT_NAME=$(systemd-escape --path "$MOUNT_PATH")
    echo ""
    echo "→ Configurazione:"
    echo "  Mount:  $MOUNT_PATH"
    echo "  Remote: $REMOTE_PATH"
    echo "  Utente: $SMB_USER"
    echo "  Unit:   $UNIT_NAME"
    echo ""
    read -rp "Confermi? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    MOUNT_CONTENT="[Unit]\nDescription=$DESCRIPTION\n\n[Mount]\nWhat=$REMOTE_PATH\nWhere=$MOUNT_PATH\nType=cifs\nOptions=rw,file_mode=0700,dir_mode=0700,uid=$USER_UID,user=$SMB_USER,password=$SMB_PASS\nDirectoryMode=0700\n\n[Install]\nWantedBy=multi-user.target"
    printf "$MOUNT_CONTENT\n" | sudo tee /etc/systemd/system/${UNIT_NAME}.mount > /dev/null
    AUTOMOUNT_CONTENT="[Unit]\nDescription=$DESCRIPTION (automount)\n\n[Automount]\nWhere=$MOUNT_PATH\nTimeoutIdleSec=60\n\n[Install]\nWantedBy=multi-user.target"
    printf "$AUTOMOUNT_CONTENT\n" | sudo tee /etc/systemd/system/${UNIT_NAME}.automount > /dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now ${UNIT_NAME}.automount
    echo ""
    echo "✓ Connessione '$CONNECTION' creata e attiva."
    echo "  Accedi a: $MOUNT_PATH"
    echo "  Si monta automaticamente al primo accesso."
 
# Rimuovi una connessione SMB
smb-disconnect:
    #!/usr/bin/env bash
    set -euo pipefail
    USER_HOME="$(realpath "$HOME")"
    echo "┌──────────────────────────────────────┐"
    echo "│  Rimozione connessione SMB           │"
    echo "└──────────────────────────────────────┘"
    echo ""
    read -rp "Nome cartella contenitore (es. nas): " CONTAINER
    read -rp "Nome connessione da rimuovere (es. server1): " CONNECTION
    MOUNT_PATH="$USER_HOME/$CONTAINER/$CONNECTION"
    UNIT_NAME=$(systemd-escape --path "$MOUNT_PATH")
    if [[ ! -f "/etc/systemd/system/${UNIT_NAME}.mount" ]]; then
        echo "✗ Nessuna connessione trovata per '$MOUNT_PATH'."
        exit 1
    fi
    echo ""
    echo "⚠ Verrà rimossa la connessione:"
    echo "  Mount: $MOUNT_PATH"
    echo "  Unit:  $UNIT_NAME"
    echo ""
    read -rp "Confermi? [s/N]: " CONFIRM
    if [[ ! "$CONFIRM" =~ ^[sS]$ ]]; then
        echo "Operazione annullata."
        exit 0
    fi
    sudo systemctl disable --now ${UNIT_NAME}.automount 2>/dev/null || true
    sudo systemctl disable --now ${UNIT_NAME}.mount 2>/dev/null || true
    sudo rm -f /etc/systemd/system/${UNIT_NAME}.mount
    sudo rm -f /etc/systemd/system/${UNIT_NAME}.automount
    sudo systemctl daemon-reload
    read -rp "Eliminare anche la cartella '$MOUNT_PATH'? [s/N]: " DELFOLDER
    if [[ "$DELFOLDER" =~ ^[sS]$ ]]; then
        rm -rf "$MOUNT_PATH"
        echo "✓ Cartella rimossa."
    fi
    echo "✓ Connessione '$CONNECTION' rimossa."
 
# Elenca le connessioni SMB attive
smb-list:
    #!/usr/bin/env bash
    echo "┌──────────────────────────────────────┐"
    echo "│  Connessioni SMB attive              │"
    echo "└──────────────────────────────────────┘"
    echo ""
    FOUND=0
    for f in /etc/systemd/system/var-*.mount; do
        [ -f "$f" ] || continue
        UNIT=$(basename "$f")
        WHERE=$(grep "^Where=" "$f" | cut -d= -f2)
        WHAT=$(grep "^What=" "$f" | cut -d= -f2)
        STATUS=$(systemctl is-active "${UNIT%.mount}.automount" 2>/dev/null || echo "inattivo")
        echo "  $WHERE → $WHAT [$STATUS]"
        FOUND=1
    done
    if [ "$FOUND" -eq 0 ]; then
        echo "  Nessuna connessione SMB configurata."
    fi
 

# Pulisci le immagini bootc non più referenziate
cleanup:
    sudo bootc image prune 2>/dev/null || sudo podman image prune -f
    @echo "✓ Pulizia completata."
