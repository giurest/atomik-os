# [Manutenzione] Ripristina configurazione MangoHud di default
reset-mangohud:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p ~/.config/MangoHud
    cp /usr/share/atomik/defaults/MangoHud/MangoHud.conf \
       ~/.config/MangoHud/MangoHud.conf
