#!/usr/bin/env bash
# Atomik OS - Fish shell setup per utenti esistenti
set -euo pipefail

MARKER=/var/lib/atomik-fish-setup-done
SCRIPT_HASH=$(sha256sum /usr/bin/atomik-fish-setup | cut -d' ' -f1)

# Se il sentinella esiste ed è aggiornato, esci
if [ -f "$MARKER" ] && [ "$(cat "$MARKER")" = "$SCRIPT_HASH" ]; then
    exit 0
fi
rm -f "$MARKER"

# Blocco gestito da Atomik: viene riscritto integralmente ad ogni run,
# delimitato da marcatori. Tutto ciò che l'utente mette FUORI dai marcatori
# viene preservato. Questo rende lo script idempotente: niente duplicati.
read -r -d '' ATOMIK_BLOCK << 'BLOCK' || true
# >>> atomik fish config >>>
# Blocco gestito automaticamente da atomik-fish-setup — non modificare a mano.
if status is-interactive
    starship init fish | source
    set -gx MANGOHUD 1
    cd $HOME
    bind f12 'commandline -i \~'
end
# <<< atomik fish config <<<
BLOCK

for HOME_DIR in /var/home/*; do
    [ -d "$HOME_DIR" ] || continue
    USERNAME=$(basename "$HOME_DIR")

    UID_VAL=$(id -u "$USERNAME" 2>/dev/null) || continue
    [ "$UID_VAL" -ge 1000 ] || continue

    # Imposta fish come shell se non lo è già
    CURRENT_SHELL=$(getent passwd "$USERNAME" | cut -d: -f7)
    if [ "$CURRENT_SHELL" != "/usr/bin/fish" ]; then
        chsh -s /usr/bin/fish "$USERNAME"
        echo "✓ Shell fish impostata per $USERNAME"
    fi

    FISH_CONFIG="$HOME_DIR/.config/fish/config.fish"
    mkdir -p "$HOME_DIR/.config/fish"

    if [ ! -f "$FISH_CONFIG" ]; then
        # Config nuovo: scrivi solo il blocco gestito
        printf '%s\n' "$ATOMIK_BLOCK" > "$FISH_CONFIG"
        echo "✓ Fish config creato per $USERNAME"
    else
        # Config esistente: rimuovi il vecchio blocco gestito (se presente)
        # e qualsiasi riga legacy sparsa, poi riscrivi il blocco pulito.
        TMP=$(mktemp)
        # 1) Elimina il blocco tra i marcatori (vecchie versioni)
        sed '/# >>> atomik fish config >>>/,/# <<< atomik fish config <<</d' \
            "$FISH_CONFIG" > "$TMP"
        # 2) Pulisci righe legacy sparse di versioni precedenti
        sed -i \
            -e '/^starship init fish | source$/d' \
            -e '/^set -gx MANGOHUD 1$/d' \
            -e '/^set fish_greeting$/d' \
            -e '/^cd \$HOME$/d' \
            -e '/^bind .*F12.*~/d' \
            -e '/^bind f12 /d' \
            -e '/^echo bind /d' \
            "$TMP"
        # 3) Rimuovi eventuali righe vuote multiple in coda
        sed -i -e :a -e '/^\n*$/{$d;N;ba}' "$TMP"
        # 4) Riappendi il blocco gestito pulito
        printf '%s\n' "$ATOMIK_BLOCK" >> "$TMP"
        mv "$TMP" "$FISH_CONFIG"
        echo "✓ Fish config aggiornato per $USERNAME"
    fi

    chown -R "$USERNAME:$USERNAME" "$HOME_DIR/.config/fish"
done

echo "$SCRIPT_HASH" > "$MARKER"
echo "✓ Fish setup completato (versione: ${SCRIPT_HASH:0:8})"
