#!/usr/bin/env bash
# Atomik OS — Mostra le differenze tra il sistema pre-update e quello attuale
set -euo pipefail

BEFORE="$HOME/.local/share/atomik/rpms-before.txt"
CURRENT=$(mktemp)

# Escludi gpg-pubkey (chiavi RPM, non pacchetti reali)
rpm -qa --queryformat '%{NAME} %{EVR}\n' | grep -v '^gpg-pubkey ' | sort > "$CURRENT"

if [ ! -f "$BEFORE" ]; then
    echo "Nessun aggiornamento precedente registrato."
    echo "Esegui 'ujust update' per tracciare il prossimo aggiornamento."
    rm -f "$CURRENT"
    exit 0
fi

# Filtra gpg-pubkey anche dal file salvato
BEFORE_CLEAN=$(mktemp)
grep -v '^gpg-pubkey ' "$BEFORE" | sort > "$BEFORE_CLEAN"

# Pacchetti aggiunti (presenti solo nel nuovo)
ADDED=$(comm -13 <(awk '{print $1}' "$BEFORE_CLEAN") <(awk '{print $1}' "$CURRENT"))

# Pacchetti rimossi (presenti solo nel vecchio)
REMOVED=$(comm -23 <(awk '{print $1}' "$BEFORE_CLEAN") <(awk '{print $1}' "$CURRENT"))

# Pacchetti aggiornati (stesso nome, versione diversa)
UPDATED=""
while IFS=' ' read -r name ver; do
    new_ver=$(awk -v n="$name" '$1 == n {print $2}' "$CURRENT")
    if [ -n "$new_ver" ] && [ "$ver" != "$new_ver" ]; then
        UPDATED="${UPDATED}  ${name}: ${ver} → ${new_ver}\n"
    fi
done < "$BEFORE_CLEAN"

echo "┌──────────────────────────────────────────┐"
echo "│  Atomik OS — Changelog aggiornamento     │"
echo "└──────────────────────────────────────────┘"
echo ""

COUNT_UPD=0
COUNT_ADD=0
COUNT_REM=0

if [ -n "$UPDATED" ]; then
    COUNT_UPD=$(echo -e "$UPDATED" | grep -c "→" || true)
fi
if [ -n "$ADDED" ]; then
    COUNT_ADD=$(echo "$ADDED" | wc -l)
fi
if [ -n "$REMOVED" ]; then
    COUNT_REM=$(echo "$REMOVED" | wc -l)
fi

if [ "$COUNT_ADD" -eq 0 ] && [ "$COUNT_REM" -eq 0 ] && [ "$COUNT_UPD" -eq 0 ]; then
    echo "  Nessuna differenza rilevata."
else
    if [ "$COUNT_UPD" -gt 0 ]; then
        echo "📦 Aggiornati ($COUNT_UPD):"
        echo -e "$UPDATED"
    fi
    if [ "$COUNT_ADD" -gt 0 ]; then
        echo "✚ Aggiunti ($COUNT_ADD):"
        echo "$ADDED" | sed 's/^/  /'
        echo ""
    fi
    if [ "$COUNT_REM" -gt 0 ]; then
        echo "✖ Rimossi ($COUNT_REM):"
        echo "$REMOVED" | sed 's/^/  /'
        echo ""
    fi
fi

rm -f "$CURRENT" "$BEFORE_CLEAN"
