#!/usr/bin/env bash
# Atomik OS — Launcher di sessione per greetd.
# Legge /tmp/atomik-session-select per decidere se partire in
# gamescope (game mode) o niri (desktop mode).

SESSION_FILE="/tmp/atomik-session-select"

if [ -f "$SESSION_FILE" ]; then
    SESSION=$(cat "$SESSION_FILE")
else
    SESSION="gamescope"
fi

case "$SESSION" in
    niri)
        exec niri-session
        ;;
    *)
        exec /usr/bin/atomik-gamescope-session
        ;;
esac
