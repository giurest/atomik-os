#!/usr/bin/env bash
# Installa le app Flatpak di base al primo avvio.
# Brave NON è qui: è installato come RPM nell'immagine (legge le policy di debloat).
# Si auto-disabilita dopo il primo completamento riuscito.
set -euo pipefail

MARKER=/var/lib/atomik-flatpak-base-done
[ -f "$MARKER" ] && exit 0

flatpak remote-add --if-not-exists flathub \
    https://flathub.org/repo/flathub.flatpakrepo

flatpak install -y --noninteractive flathub \
    io.github.kolunmi.Bazaar \
    com.github.tchx84.Flatseal \
    org.telegram.desktop

touch "$MARKER"
