#!/usr/bin/env python3
"""Atomik Panel — Centro di controllo per Atomik OS"""

import subprocess
import os
import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw

