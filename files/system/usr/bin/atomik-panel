#!/usr/bin/env python3
"""
Atomik Panel v0.2.1 — Centro di controllo universale per sistemi bootc
Legge dinamicamente le ricette da ujust/just, compatibile con qualsiasi distro bootc.
"""

import subprocess
import os
import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw

VERSION = "0.2.0"

CATEGORY_ORDER = ["Sistema", "Utenti", "Desktop", "Gaming", "Rete", "Git", "Avanzato", "Altro"]

SWITCH_RECIPES = [
    {"id": "__switch_desktop", "name": "Switch → Desktop", "desc": "bootc switch verso Atomik Desktop"},
    {"id": "__switch_puregaming", "name": "Switch → PureGaming", "desc": "bootc switch verso Atomik PureGaming"},
    {"id": "__switch_desktop_nvidia", "name": "Switch → Desktop NVIDIA", "desc": "bootc switch verso Atomik Desktop NVIDIA"},
    {"id": "__switch_puregaming_nvidia", "name": "Switch → PureGaming NVIDIA", "desc": "bootc switch verso Atomik PureGaming NVIDIA"},
]

SWITCH_MAP = {
    "__switch_desktop": "ghcr.io/giurest/atomik-desktop:latest",
    "__switch_puregaming": "ghcr.io/giurest/atomik-puregaming:latest",
    "__switch_desktop_nvidia": "ghcr.io/giurest/atomik-desktop-nvidia:latest",
    "__switch_puregaming_nvidia": "ghcr.io/giurest/atomik-puregaming-nvidia:latest",
}

TERMINAL = None
JUST_CMD = None


def get_os_name():
    """Legge il nome OS da os-release"""
    try:
        with open("/etc/os-release") as f:
            for line in f:
                if line.startswith("PRETTY_NAME="):
                    return line.split("=", 1)[1].strip().strip('"')
    except Exception:
        pass
    return "Sistema sconosciuto"


def is_atomik():
    """Rileva se siamo su Atomik OS"""
    try:
        with open("/etc/os-release") as f:
            return "Atomik" in f.read()
    except Exception:
        return False


def find_just_command():
    """Trova ujust o just disponibile nel sistema"""
    for cmd in ["ujust", "just"]:
        if subprocess.run(["which", cmd], capture_output=True).returncode == 0:
            return cmd
    return None


def find_terminal():
    """Rileva il terminale disponibile"""
    for t in ["alacritty", "gnome-terminal", "konsole", "xfce4-terminal", "foot", "kitty", "xterm"]:
        if subprocess.run(["which", t], capture_output=True).returncode == 0:
            return t
    return "xterm"


def parse_just_list():
    """Legge le ricette da ujust/just con categorie dal tag [Categoria]"""
    recipes = []
    if not JUST_CMD:
        return recipes
    try:
        result = subprocess.run(
            [JUST_CMD, "--list", "--list-heading", "", "--list-prefix", ""],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode != 0:
            return recipes

        for line in result.stdout.strip().splitlines():
            line = line.strip()
            if not line:
                continue
            if "#" in line:
                name, desc = line.split("#", 1)
                name = name.strip()
                desc = desc.strip()
                category = "Altro"
                if desc.startswith("[") and "]" in desc:
                    category = desc[1:desc.index("]")]
                    desc = desc[desc.index("]") + 1:].strip()
                recipes.append({
                    "id": name,
                    "name": name,
                    "desc": desc,
                    "category": category,
                })
            else:
                recipes.append({
                    "id": line.strip(),
                    "name": line.strip(),
                    "desc": "",
                    "category": "Altro",
                })
    except Exception:
        pass
    return recipes


def categorize_recipes(recipes):
    """Raggruppa le ricette per categoria mantenendo l'ordine definito"""
    groups = {}
    for r in recipes:
        cat = r.get("category", "Altro")
        if cat not in groups:
            groups[cat] = []
        groups[cat].append(r)

    categories = []
    for name in CATEGORY_ORDER:
        if name in groups:
            categories.append({"name": name, "recipes": groups.pop(name)})
    for name, recs in groups.items():
        categories.append({"name": name, "recipes": recs})
    return categories


def launch_in_terminal(recipe_id):
    """Lancia un comando nel terminale rilevato"""
    if recipe_id.startswith("__switch_"):
        image = SWITCH_MAP[recipe_id]
        cmd = f"sudo bootc switch {image}; echo ''; read -rp 'Premi INVIO per chiudere...'"
    else:
        run_cmd = JUST_CMD or "ujust"
        cmd = f"{run_cmd} {recipe_id}; echo ''; read -rp 'Premi INVIO per chiudere...'"

    if TERMINAL == "alacritty":
        subprocess.Popen(["alacritty", "--title", f"Atomik — {recipe_id}", "-e", "bash", "-c", cmd])
    elif TERMINAL == "gnome-terminal":
        subprocess.Popen(["gnome-terminal", "--", "bash", "-c", cmd])
    elif TERMINAL == "konsole":
        subprocess.Popen(["konsole", "-e", "bash", "-c", cmd])
    elif TERMINAL == "foot":
        subprocess.Popen(["foot", "bash", "-c", cmd])
    elif TERMINAL == "kitty":
        subprocess.Popen(["kitty", "bash", "-c", cmd])
    else:
        subprocess.Popen([TERMINAL, "-e", f"bash -c '{cmd}'"])


class AtomikPanel(Adw.Application):
    def __init__(self):
        super().__init__(application_id="io.github.giurest.atomik-panel")
        self.connect("activate", self.on_activate)

    def build_ui(self, win):
        """Costruisce l'interfaccia leggendo le ricette"""
        on_atomik = is_atomik()
        os_name = get_os_name()
        recipes = parse_just_list()
        categories = categorize_recipes(recipes) if recipes else []

        header = Adw.HeaderBar()
        title_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8, valign=Gtk.Align.CENTER)
        icon = Gtk.Image.new_from_icon_name("atomik-os")
        icon.set_pixel_size(24)
        title_box.append(icon)
        title_label = Gtk.Label(label="Atomik Panel")
        title_label.add_css_class("title-1")
        title_box.append(title_label)
        header.set_title_widget(title_box)

        refresh_btn = Gtk.Button(icon_name="view-refresh-symbolic", tooltip_text="Ricarica ricette")
        refresh_btn.connect("clicked", self.on_refresh, win)
        header.pack_end(refresh_btn)

        about_btn = Gtk.Button(icon_name="help-about-symbolic", tooltip_text="Informazioni")
        about_btn.connect("clicked", self.on_about, win)
        header.pack_end(about_btn)

        scrolled = Gtk.ScrolledWindow(vexpand=True)
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        main_box.set_margin_top(18)
        main_box.set_margin_bottom(18)
        main_box.set_margin_start(18)
        main_box.set_margin_end(18)

        # Info sistema
        sys_group = Adw.PreferencesGroup()
        if on_atomik:
            sys_row = Adw.ActionRow(title=os_name, subtitle=f"Atomik Panel v{VERSION}")
        elif recipes:
            sys_row = Adw.ActionRow(
                title=os_name,
                subtitle=f"Ricette locali caricate tramite {JUST_CMD} — Atomik Panel v{VERSION}",
            )
        else:
            sys_row = Adw.ActionRow(
                title=os_name,
                subtitle=f"Nessuna ricetta trovata — Atomik Panel v{VERSION}",
            )
        sys_group.add(sys_row)
        main_box.append(sys_group)

        # Ricette ujust/just
        for category in categories:
            group = Adw.PreferencesGroup(title=category["name"])
            for recipe in category["recipes"]:
                row = Adw.ActionRow(title=recipe["name"], subtitle=recipe["desc"])
                btn = Gtk.Button(
                    icon_name="media-playback-start-symbolic",
                    valign=Gtk.Align.CENTER,
                    css_classes=["flat"],
                    tooltip_text=f"{JUST_CMD or 'ujust'} {recipe['id']}",
                )
                btn.connect("clicked", self.on_run, recipe["id"])
                row.add_suffix(btn)
                row.set_activatable_widget(btn)
                group.add(row)
            main_box.append(group)

        # Sezione switch Atomik (sempre visibile)
        switch_group = Adw.PreferencesGroup(title="Installa Atomik OS")
        for recipe in SWITCH_RECIPES:
            row = Adw.ActionRow(title=recipe["name"], subtitle=recipe["desc"])
            btn = Gtk.Button(
                icon_name="media-playback-start-symbolic",
                valign=Gtk.Align.CENTER,
                css_classes=["flat"],
            )
            btn.connect("clicked", self.on_run, recipe["id"])
            row.add_suffix(btn)
            row.set_activatable_widget(btn)
            switch_group.add(row)
        main_box.append(switch_group)

        scrolled.set_child(main_box)

        toolbar_view = Adw.ToolbarView()
        toolbar_view.add_top_bar(header)
        toolbar_view.set_content(scrolled)

        win.set_content(toolbar_view)

    def on_activate(self, app):
        global TERMINAL, JUST_CMD
        TERMINAL = find_terminal()
        JUST_CMD = find_just_command()

        win = Adw.ApplicationWindow(application=app)
        win.set_title("Atomik Panel")
        win.set_default_size(520, 760)

        self.build_ui(win)
        win.present()

    def on_refresh(self, button, win):
        """Ricostruisce l'UI con le ricette aggiornate"""
        self.build_ui(win)

    def on_about(self, button, win):
        """Mostra la finestra informazioni"""
        about = Adw.AboutDialog(
            application_name="Atomik Panel",
            version=VERSION,
            developer_name="Giurest Labs",
            comments="Centro di controllo universale per sistemi bootc.\nLegge dinamicamente le ricette da ujust/just.",
            website="https://github.com/giurest/atomik-os",
            license_type=Gtk.License.GPL_3_0,
        )
        about.present(win)

    def on_run(self, button, recipe_id):
        launch_in_terminal(recipe_id)


if __name__ == "__main__":
    app = AtomikPanel()
    app.run()
