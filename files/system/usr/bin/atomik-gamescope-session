#!/usr/bin/env bash
# Atomik OS — Gamescope Session (game mode, sperimentale)
# Lancia gamescope con Steam in Big Picture / Deck UI.
# Selezionabile dal greeter come sessione alternativa a Niri.

# Esporta DISPLAY al bus D-Bus (richiesto da Steam Flatpak)
export DISPLAY=:0
dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_SESSION_TYPE

exec gamescope \
    --steam \
    --force-orientation right \
    -f \
    -- bash -c 'dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY; flatpak run com.valvesoftware.Steam -gamepadui -steamos3 -steampal -nointro'
