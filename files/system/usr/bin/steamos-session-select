#!/usr/bin/env bash
# Atomik OS — Switch tra game mode e desktop mode.
# Chiamato da Steam quando l'utente sceglie "Passa al Desktop".
# Salva la sessione scelta e riavvia greetd.

SESSION="${1:-gamescope}"

case "$SESSION" in
    plasma|desktop)
        # "plasma" è il nome che Steam usa internamente per "desktop mode"
        echo "niri" > /tmp/atomik-session-select
        ;;
    gamescope|steamos)
        echo "gamescope" > /tmp/atomik-session-select
        ;;
    *)
        echo "gamescope" > /tmp/atomik-session-select
        ;;
esac

# Termina la sessione corrente — greetd rilancia con la nuova sessione
# basandosi sul file /tmp/atomik-session-select.
steam -shutdown 2>/dev/null
sleep 2
loginctl terminate-session "${XDG_SESSION_ID}" 2>/dev/null
