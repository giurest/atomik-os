#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# vm-alloc-ip — Alloca la prossima coppia (MAC, IP) libera sulla rete libvirt.
#
# Considera "occupato" un IP se è:
#   (a) in una DHCP reservation nella network XML  → occupazione permanente
#   (b) in un lease DHCP attivo (net-dhcp-leases)  → occupazione dinamica
#   (c) risponde a ping                            → difesa finale (VM orfana)
# L'unione (a)+(b)+(c) copre anche lo stato sporco "VM senza reservation",
# che altrimenti causerebbe un conflitto IP (due macchine, stesso indirizzo).
#
# NON scrive nulla: propone solo una coppia valida. La reservation la scrive
# il chiamante (atomik-server) con:
#     virsh net-update default add ip-dhcp-host \
#         "<host mac='<MAC>' ip='<IP>'/>" --live --config
#
# Output (stdout, pipe-friendly):   <MAC> <IP>
# Diagnostica/errori → stderr, così stdout resta pulito per:
#     read -r VM_MAC VM_IP < <(/usr/libexec/atomik/vm-alloc-ip)
#
# Nota: net-dhcp-leases mostra i lease dinamici ma NON le reservation statiche
#       → la XML resta indispensabile per (a). I due sono complementari.
# ─────────────────────────────────────────────────────────────────────────────
set -uo pipefail
export LC_ALL=C

NET="default"
SUBNET="192.168.122"
IP_MIN=2
IP_MAX=254

log() { printf '%s\n' "$@" >&2; }

# ── (a) Reservation dalla network XML (UNICA fonte di verità) ────────────────
XML="$(sudo virsh net-dumpxml "$NET" 2>/dev/null || true)"
if [[ -z "$XML" ]]; then
    log "✗ Impossibile leggere la rete libvirt '$NET'."
    log "  Verifica con: sudo virsh net-list --all"
    exit 1
fi

USED_IPS="$(printf '%s\n' "$XML" \
    | grep -oE "ip='${SUBNET}\.[0-9]+'" \
    | sed "s/.*\.//; s/'//" || true)"

USED_MACS="$(printf '%s\n' "$XML" \
    | grep -oE "mac='[0-9a-fA-F:]+'" \
    | sed "s/mac='//; s/'//" \
    | tr 'A-F' 'a-f' || true)"

# ── NIENTE lease: i lease residui di VM cancellate restano in cache dnsmasq
#    fino a scadenza e falsano l'allocazione (bloccano IP in realtà liberi).
#    La XML è la sola verità: reservation presente = IP occupato.

# ── Trova il primo IP libero, con ping come difesa finale (c) ────────────────
CHOSEN_IP=""
for (( o=IP_MIN; o<=IP_MAX; o++ )); do
    # salta se già in reservation o lease
    if printf '%s\n' "$USED_IPS" | grep -qx "$o"; then
        continue
    fi
    # difesa finale: se qualcuno risponde a quell'IP, è vivo → saltalo
    if ping -c1 -W1 "${SUBNET}.${o}" &>/dev/null; then
        log "⚠ ${SUBNET}.${o} risponde a ping ma non è né in reservation né in lease."
        log "  Probabile VM orfana (creata fuori dalle recipe). Salto questo IP."
        continue
    fi
    CHOSEN_IP="${SUBNET}.${o}"
    break
done

if [[ -z "$CHOSEN_IP" ]]; then
    log "✗ Nessun IP libero in ${SUBNET}.${IP_MIN}–${IP_MAX}."
    log "  Libera spazio rimuovendo VM inutilizzate con 'ujust vm-delete'."
    exit 1
fi

# ── Genera un MAC 52:54:00:xx:xx:xx non collidente ───────────────────────────
CHOSEN_MAC=""
for _ in $(seq 1 50); do
    CANDIDATE="$(printf '52:54:00:%02x:%02x:%02x' \
        $((RANDOM % 256)) $((RANDOM % 256)) $((RANDOM % 256)))"
    if ! printf '%s\n' "$USED_MACS" | grep -qx "$CANDIDATE"; then
        CHOSEN_MAC="$CANDIDATE"
        break
    fi
done

if [[ -z "$CHOSEN_MAC" ]]; then
    log "✗ Impossibile generare un MAC unico dopo 50 tentativi (improbabile)."
    exit 1
fi

# ── Output ───────────────────────────────────────────────────────────────────
log "→ Allocati: MAC ${CHOSEN_MAC} · IP ${CHOSEN_IP}"
printf '%s %s\n' "$CHOSEN_MAC" "$CHOSEN_IP"