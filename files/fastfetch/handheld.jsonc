{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/atomik-logo.txt",
    "type": "file",
    "color": {
      "1": "green",
      "2": "cyan"
    },
    "padding": {
      "top": 1,
      "left": 2
    }
  },
  "display": {
    "separator": " → ",
    "color": "green"
  },
  "modules": [
    {
      "type": "title",
      "format": "{user-name}@{host-name}"
    },
    "separator",
    {
      "type": "os",
      "format": "Atomik OS - Handheld"
    },
    {
      "type": "kernel",
      "format": "{sysname} {release}"
    },
    "uptime",
    "packages",
    "shell",
    "display",
    "de",
    "cpu",
    "battery",
    "memory",
    "colors"
  ]
}
